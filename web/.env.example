# Web app configuration (set these in Vercel → Project → Settings → Environment
# Variables, then redeploy). Both are OPTIONAL — with neither set, the app runs
# fully local (no sync), which is a valid mode.

# Base URL of the deployed sync API (no trailing slash).
VITE_SYNC_URL=https://your-api.up.railway.app

# The SAME token as the API's SYNC_TOKEN.
VITE_SYNC_TOKEN=replace-with-a-long-random-string
