# Sync API configuration (copy to your host's env vars — do NOT commit real values)

# Postgres connection string. Railway's Postgres plugin provides this
# automatically as DATABASE_URL; for the Pi, point at your local Postgres.
DATABASE_URL=postgresql://user:password@host:5432/p90x

# One long random shared token. Generate with:  openssl rand -hex 32
# The web app must send the SAME value as VITE_SYNC_TOKEN.
SYNC_TOKEN=replace-with-a-long-random-string

# Allowed browser origin(s) for CORS — your deployed web app URL.
# Comma-separated; use * only for local development.
CORS_ORIGINS=https://your-app.vercel.app
