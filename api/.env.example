# Sync API configuration (copy to your host's env vars — do NOT commit real values)

# Postgres connection string.
#  - Neon: use the POOLED connection string (host contains "-pooler"), required
#    for serverless. Copy it from the Neon dashboard → Connection Details.
#  - Railway/Render/Pi: the plugin's DATABASE_URL works as-is.
DATABASE_URL=postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/p90x?sslmode=require

# Member tokens: a JSON map of token -> account name. Each person gets their own
# token; their data is isolated by account. Generate tokens with:
#   openssl rand -hex 24
SYNC_TOKENS={"paste-a-long-random-token":"andrea","paste-another":"wife"}

# (Optional, single-user shortcut) One token, mapped to account "default".
# Ignored if SYNC_TOKENS is set. Prefer SYNC_TOKENS above.
# SYNC_TOKEN=replace-with-a-long-random-string

# Allowed browser origin(s) for CORS — your deployed web app URL.
# Comma-separated; use * only for local development.
CORS_ORIGINS=https://p90xtracker.vercel.app
